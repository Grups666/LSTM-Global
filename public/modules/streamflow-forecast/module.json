{
  "id": "streamflow-forecast",
  "name": "LSTM Global Streamflow Forecast",
  "version": "0.1.0",
  "assetVersion": "2026-06-23-state-residual-hist7-persistence-blend",
  "description": "Global 1-7 day probabilistic streamflow forecast preview from the GFS residual-state forecaster with a deployment-safe persistence blend and recent supervised validation where daily observations are available.",
  "author": "Spatial Research Team",
  "icon": "activity",
  "entry": "./index.js",
  "className": "StreamflowForecastModule",
  "importKind": "module-manifest",
  "defaultLoad": true,
  "layerId": "streamflow-forecast-basins",
  "layerName": "Global Streamflow Forecast",
  "datasets": [
    {
      "id": "streamflow-forecast-dashboard",
      "file": "./data/dashboard-data-state-residual-hist7-persistence-blend-20260623.json"
    }
  ],
  "provides": {
    "layers": [
      {
        "id": "streamflow-forecast-basins",
        "name": "Global Streamflow Forecast",
        "type": "vector",
        "source": "module.basins",
        "interactive": true
      }
    ],
    "panels": [
      {
        "id": "streamflow-forecast-inspector",
        "name": "Streamflow Forecast Inspector",
        "position": "right",
        "trigger": "feature:click",
        "condition": {
          "layer": "streamflow-forecast-basins",
          "module": "streamflow-forecast"
        }
      }
    ],
    "dataProducts": [
      {
        "id": "recent-gfs-streamflow-validation",
        "type": "forecast-validation-summary",
        "description": "Lead-wise P05/P50/P95 streamflow forecast series from the residual-state forecaster plus D-1 persistence blend, joined with recent observed daily discharge where available."
      }
    ]
  }
}
